<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fabio Web | Portfolio</title>

    <!-- CORREÇÃO: Google Font correta -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        /* 1. FUNDO E CONFIGURAÇÃO GERAL */
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            min-height: 100vh;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('foto.fabio1.jpg');
            background-size: cover; background-position: center; background-attachment: fixed;
            color: #fff; padding: 40px 20px;
            overflow-x: hidden;
        }

        h1 { 
            font-size: 2.2rem; 
            margin-bottom: 40px; 
            text-align: center; 
            color: #b39359; 
            text-transform: uppercase; 
            letter-spacing: 2px; 
        }

        /* 2. GRID DOS CARDS (SEM ALTERAR ESTRUTURA) */
        .projects-grid { 
            display: flex; flex-wrap: wrap; justify-content: center; 
            gap: 20px; max-width: 1200px; width: 100%; 
        }

        .card {
            background: rgba(26, 26, 26, 0.95); 
            width: 350px; 
            border-radius: 25px;
            cursor: pointer;
            border: 1px solid rgba(179, 147, 89, 0.3);
            transition: 0.4s;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            backdrop-filter: blur(10px);
            text-decoration: none;
            color: inherit;
        }

        .card:hover { 
            transform: translateY(-10px); 
            border-color: #b39359; 
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6); 
        }

        .card-banner img { width: 100%; height: auto; display: block; }
        .card-content { padding: 25px; text-align: center; flex-grow: 1; }

        .card h3 { 
            font-size: 1.4rem; 
            color: #b39359; 
            margin-bottom: 10px; 
            text-transform: uppercase; 
        }

        .card p { 
            font-size: 0.9rem; 
            color: #ddd; 
            line-height: 1.5; 
        }

        .icon-box { 
            font-size: 60px; 
            margin: 15px 0; 
            display: block; 
            color: #b39359; 
        }

        /* 3. MODAL (CORRIGIDO E ESTÁVEL) */
        #projectModal {
            display: none;
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            width: 95%;
            height: 90%;
            background: #fff;
            border-radius: 20px;
            overflow: hidden;
            position: relative;
        }

        iframe {
            width: 100%;
            height: 100%;
            border: none;
            background: white;
        }

        .close-btn {
            position: absolute;
            top: 10px;
            right: 20px;
            font-size: 35px;
            color: #000;
            cursor: pointer;
            font-weight: bold;
            z-index: 1001;
        }

        @media (max-width: 768px) {
            .card { width: 100%; }
        }
    </style>
</head>

<body>

<h1>Web Portfolio</h1>

<div class="projects-grid">

    <!-- CARD 1 -->
    <div class="card" onclick="openProject('estoque.html')">
        <div class="card-banner">
            <img src="imagem.Sollene%20Group.png" alt="Sollene Group">
        </div>
        <div class="card-content">
            <h3>Sollene Group</h3>
            <p>International inventory system with financial automation.</p>
        </div>
    </div>

    <!-- CARD 2 -->
    <div class="card" onclick="openProject('malta.html')">
        <div class="card-content">
            <span class="icon-box">🌍</span>
            <h3>Malta Project</h3>
            <p>Business expansion and global logistics platform.</p>
        </div>
    </div>

    <!-- CARD 3 -->
    <a href="resume.pdf" target="_blank" class="card">
        <div class="card-content">
            <span class="icon-box">📄</span>
            <h3>Summary</h3>
            <p>Professional experience and curriculum PDF.</p>
        </div>
    </a>

</div>

<!-- MODAL -->
<div id="projectModal">
    <div class="modal-content">
        <span class="close-btn" onclick="closeProject()">&times;</span>
        <iframe id="projectFrame"></iframe>
    </div>
</div>

<script>
function openProject(url) {
    document.getElementById('projectFrame').src = url;
    document.getElementById('projectModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

function closeProject() {
    document.getElementById('projectFrame').src = '';
    document.getElementById('projectModal').style.display = 'none';
    document.body.style.overflow = 'auto';
}

// fecha clicando fora
window.onclick = function(event) {
    const modal = document.getElementById('projectModal');
    if (event.target === modal) {
        closeProject();
    }
}
</script>

</body>
</html>

